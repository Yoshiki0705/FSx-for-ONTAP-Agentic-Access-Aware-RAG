{
  "name": "bedrock-agent-core-integration-tests",
  "version": "1.0.0",
  "description": "Integration tests for Amazon Bedrock AgentCore features",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose"
  },
  "keywords": [
    "bedrock",
    "agent",
    "cdk",
    "integration-test"
  ],
  "author": "Kiro AI",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "aws-cdk-lib": "^2.120.0",
    "constructs": "^10.3.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "../../lib/**/*.ts",
      "!../../lib/**/*.d.ts",
      "!../../lib/**/index.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
