# Environment variables for embedding server
# These are overridden by Docker environment variables at runtime

ENV_REGION=ap-northeast-1
ENV_OPEN_SEARCH_SERVERLESS_COLLECTION_NAME=
ENV_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
ENV_DATA_DIR=/opt/netapp/ai/data
ENV_DB_DIR=/opt/netapp/ai/db
ENV_INDEX_NAME=bedrock-knowledge-base-default-index
ENV_WATCH_MODE=false
