/**
 * CSRF トークン取得API - Phase 1 Task 1.2
 * 
 * 機能:
 * - 新しいCSRFトークンの生成・配布
 * - セッションベースのトークン管理
 * - Cookieへのトークン設定
 */

import { NextRequest, NextResponse } from 'next/server';
import { CSRFProtection } from '@/lib/security/csrf-protection';
import { sessionManager } from '@/lib/auth/session-manager';

const CSRF_SECRET = process.env.CSRF_SECRET || 'your-csrf-secret-change-in-production-2024';

/**
 * CSRFトークン取得 (GET)
 */
export async function GET(request: NextRequest) {
  try {
    // セッション確認
    const session = await sessionManager.getSessionFromCookies();
    
    if (!session) {
      return NextResponse.json(
        { error: 'Authentication required' },
        { status: 401 }
      );
    }

    // セッションベースのCSRFトークンを生成
    const token = CSRFProtection.generateSessionToken(session.sessionId, CSRF_SECRET);

    // レスポンス作成
    const response = NextResponse.json({
      success: true,
      token,
      expiresAt: new Date(Date.now() + 3600000).toISOString() // 1時間後
    });

    // Cookieにトークンを設定
    const cookieHeader = CSRFProtection.generateCookieHeader(
      token,
      process.env.NODE_ENV === 'production'
    );
    
    response.headers.set('Set-Cookie', cookieHeader);

    console.log(`✅ CSRFトークン生成: セッション ${session.sessionId}`);

    return response;

  } catch (error) {
    console.error('❌ CSRFトークン生成エラー:', error);
    return NextResponse.json(
      { error: 'Failed to generate CSRF token' },
      { status: 500 }
    );
  }
}

/**
 * CSRFトークン検証 (POST)
 */
export async function POST(request: NextRequest) {
  try {
    const body = await request.json();
    const { token } = body;

    if (!token) {
      return NextResponse.json(
        { error: 'Token is required' },
        { status: 400 }
      );
    }

    // セッション確認
    const session = await sessionManager.getSessionFromCookies();
    
    if (!session) {
      return NextResponse.json(
        { error: 'Authentication required' },
        { status: 401 }
      );
    }

    // トークン検証
    const isValid = CSRFProtection.verifySessionToken(
      token,
      session.sessionId,
      CSRF_SECRET
    );

    if (!isValid) {
      return NextResponse.json(
        { error: 'Invalid CSRF token' },
        { status: 403 }
      );
    }

    console.log(`✅ CSRFトークン検証成功: セッション ${session.sessionId}`);

    return NextResponse.json({
      success: true,
      valid: true,
      message: 'CSRF token is valid'
    });

  } catch (error) {
    console.error('❌ CSRFトークン検証エラー:', error);
    return NextResponse.json(
      { error: 'Failed to verify CSRF token' },
      { status: 500 }
    );
  }
}