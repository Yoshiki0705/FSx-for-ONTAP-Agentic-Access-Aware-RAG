import { NextRequest, NextResponse } from 'next/server';
import { FSxClient, DescribeFileSystemsCommand } from '@aws-sdk/client-fsx';

export const dynamic = 'force-dynamic';

// FSxクライアント初期化
const fsxClient = new FSxClient({
  region: process.env.AWS_REGION || 'ap-northeast-1',
});

// ユーザーディレクトリ情報の型定義
interface UserDirectoryInfo {
  username: string;
  accessibleDirectories: string[];
  directoryType: 'actual' | 'simulated' | 'test' | 'unavailable';
  fsxFileSystemId?: string;
  fsxMountPath?: string;
  lastChecked: string;
  permissions: {
    read: boolean;
    write: boolean;
    execute: boolean;
  };
  notes?: string;
}

// テストユーザーのディレクトリマッピング
const TEST_USER_DIRECTORIES: { [key: string]: string[] } = {
  'testuser': ['/shared/testuser', '/public', '/documents/testuser'],
  'admin': ['/shared', '/public', '/private', '/admin', '/documents', '/backups'],
  'testuser0': ['/shared/testuser0', '/public', '/documents/testuser0'],
  'testuser1': ['/shared/testuser1', '/public', '/documents/testuser1'],
  'testuser2': ['/shared/testuser2', '/public', '/documents/testuser2'],
  'testuser3': ['/shared/testuser3', '/public', '/documents/testuser3'],
  'testuser4': ['/shared/testuser4', '/public', '/documents/testuser4'],
  'testuser5': ['/shared/testuser5', '/public', '/documents/testuser5'],
};

// FSx for ONTAPファイルシステムの検索
async function findFSxFileSystem(): Promise<{
  fileSystemId?: string;
  mountPath?: string;
  available: boolean;
}> {
  try {
    const command = new DescribeFileSystemsCommand({});
    
    const response = await fsxClient.send(command);
    const ontapFileSystems = response.FileSystems?.filter(fs => 
      fs.FileSystemType === 'ONTAP' && 
      fs.Lifecycle === 'AVAILABLE'
    ) || [];

    if (ontapFileSystems.length > 0) {
      const fs = ontapFileSystems[0];
      return {
        fileSystemId: fs.FileSystemId,
        mountPath: fs.DNSName ? `/mnt/${fs.DNSName}` : '/mnt/fsx-ontap',
        available: true
      };
    }

    return { available: false };
  } catch (error) {
    console.error('FSx file system lookup failed:', error);
    return { available: false };
  }
}

// 実際のディレクトリアクセス権限をチェック（シミュレーション）
async function checkActualDirectoryAccess(
  username: string, 
  fsxInfo: { fileSystemId?: string; mountPath?: string; available: boolean }
): Promise<string[]> {
  // 実際の実装では、FSx for ONTAPのSVM（Storage Virtual Machine）APIや
  // ONTAP REST APIを使用してユーザーのアクセス権限を確認します
  
  if (!fsxInfo.available || !fsxInfo.fileSystemId) {
    return [];
  }

  // シミュレーション: 実際のFSxが利用可能な場合の権限チェック
  try {
    // 実際の実装例（コメントアウト）:
    // const ontapClient = new ONTAPRestClient({
    //   endpoint: fsxInfo.mountPath,
    //   credentials: {...}
    // });
    // const userPermissions = await ontapClient.getUserPermissions(username);
    // return userPermissions.accessiblePaths;

    // シミュレーション: ユーザー名に基づく権限生成
    const baseDirectories = ['/shared', '/public'];
    const userSpecificDirs = [`/users/${username}`, `/home/${username}`];
    
    // 管理者権限の判定
    if (username === 'admin') {
      return [...baseDirectories, ...userSpecificDirs, '/admin', '/system', '/backups'];
    }

    // 一般ユーザー権限
    return [...baseDirectories, ...userSpecificDirs, `/documents/${username}`];
    
  } catch (error) {
    console.error('Directory access check failed:', error);
    return [];
  }
}

export async function GET(request: NextRequest) {
  console.log('[FSx Directories API] API endpoint called');
  
  const { searchParams } = new URL(request.url);
  const username = searchParams.get('username');
  
  if (!username) {
    return NextResponse.json({
      success: false,
      error: 'Username parameter is required',
      timestamp: new Date().toISOString()
    }, { status: 400 });
  }

  try {
    console.log(`[FSx Directories API] Checking directories for user: ${username}`);

    // FSx for ONTAPファイルシステムの確認
    const fsxInfo = await findFSxFileSystem();
    console.log(`[FSx Directories API] FSx available: ${fsxInfo.available}`);

    let directoryInfo: UserDirectoryInfo;

    if (fsxInfo.available && fsxInfo.fileSystemId) {
      // 実際のFSx for ONTAPが利用可能な場合
      const actualDirectories = await checkActualDirectoryAccess(username, fsxInfo);
      directoryInfo = {
        username,
        accessibleDirectories: actualDirectories,
        directoryType: 'actual',
        fsxFileSystemId: fsxInfo.fileSystemId,
        fsxMountPath: fsxInfo.mountPath,
        lastChecked: new Date().toISOString(),
        permissions: {
          read: true,
          write: username === 'admin' || actualDirectories.some(dir => dir.includes(username)),
          execute: true
        },
        notes: `FSx for ONTAP (${fsxInfo.fileSystemId}) から実際の権限を取得`
      };
    } else if (TEST_USER_DIRECTORIES[username]) {
      // テストユーザーの場合
      directoryInfo = {
        username,
        accessibleDirectories: TEST_USER_DIRECTORIES[username],
        directoryType: 'test',
        lastChecked: new Date().toISOString(),
        permissions: {
          read: true,
          write: username === 'admin',
          execute: true
        },
        notes: 'テストユーザー用のシミュレートされたディレクトリ権限'
      };
    } else {
      // FSxが利用不可能または未知のユーザーの場合
      const simulatedDirectories = [
        '/shared',
        '/public',
        `/users/${username}`,
        `/documents/${username}`
      ];

      directoryInfo = {
        username,
        accessibleDirectories: simulatedDirectories,
        directoryType: fsxInfo.available ? 'simulated' : 'unavailable',
        lastChecked: new Date().toISOString(),
        permissions: {
          read: true,
          write: false,
          execute: false
        },
        notes: fsxInfo.available 
          ? 'FSx for ONTAPは利用可能ですが、ユーザー権限情報を取得できませんでした'
          : 'FSx for ONTAPが利用できないため、シミュレートされたディレクトリを表示'
      };
    }

    console.log(`[FSx Directories API] Directory type: ${directoryInfo.directoryType}, Count: ${directoryInfo.accessibleDirectories.length}`);

    return NextResponse.json({
      success: true,
      data: directoryInfo,
      timestamp: new Date().toISOString()

  } catch (error) {
    console.error('[FSx Directories API] Error:', error);
    
    // エラー時のフォールバック
    const fallbackDirectories = TEST_USER_DIRECTORIES[username] || [
      '/shared',
      '/public',
      `/users/${username}`
    ];

    const fallbackInfo: UserDirectoryInfo = {
      username,
      accessibleDirectories: fallbackDirectories,
      directoryType: 'unavailable',
      lastChecked: new Date().toISOString(),
      permissions: {
        read: true,
        write: false,
        execute: false
      },
      notes: 'システムエラーのため、フォールバックディレクトリを表示'
    };

    return NextResponse.json({
      success: true,
      data: fallbackInfo,
      fallback: true,
      error: `FSx API error: ${error}`,
      timestamp: new Date().toISOString()
  }
}