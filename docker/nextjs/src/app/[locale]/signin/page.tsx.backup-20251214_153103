'use client';

import { useState } from 'react';
import { useSignIn } from '../../../hooks/useSignIn';
import { useParams } from 'next/navigation';

// Disable static generation for this page
export const dynamic = 'force-dynamic';
export const revalidate = 0;

/**
 * サインインページ - 国際化対応版
 */
export default function SignInPage() {
  const params = useParams();
  const locale = (params?.locale as string) || 'ja';
  const [username, setUsername] = useState('');
  const [password, setPassword] = useState('');
  const { isLoading, error, signIn } = useSignIn();

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    await signIn(username, password);
  };

  return (
    <div className="h-screen flex overflow-hidden">
      <BrandImageSection locale={locale} />
      <SignInFormSection
        locale={locale}
        username={username}
        password={password}
        onUsernameChange={setUsername}
        onPasswordChange={setPassword}
        onSubmit={handleSubmit}
        isLoading={isLoading}
        error={error}
      />
    </div>
  );
}

/**
 * ブランド画像セクション - 国際化対応版
 */
function BrandImageSection({ locale }: { locale: string }) {
  const title = locale === 'en' 
    ? 'RAG Application with NetApp ONTAP'
    : 'NetApp ONTAP を活用した RAG アプリケーション';
  
  const subtitle = locale === 'en'
    ? 'Intelligent Data Infrastructure for Enterprise AI'
    : 'エンタープライズ AI のためのインテリジェントデータインフラストラクチャ';

  const altText = locale === 'en'
    ? 'NetApp building with Intelligent Data Infrastructure signage'
    : 'インテリジェントデータインフラストラクチャの看板があるNetAppビル';

  return (
    <div className="hidden lg:flex lg:w-1/2 relative">
      <img
        src="/images/main-image.jpg"
        alt={altText}
        className="w-full h-full object-cover"
      />
      {/* グラデーションオーバーレイ - 下部を濃く */}
      <div className="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
      {/* テキストコンテンツ - 下部に固定配置 */}
      <div className="absolute bottom-0 left-0 right-0 p-12 text-white">
        <h1 className="text-4xl font-bold mb-4 drop-shadow-2xl">
          {title}
        </h1>
        <p className="text-xl opacity-95 drop-shadow-lg">
          {subtitle}
        </p>
      </div>
    </div>
  );
}

/**
 * サインインフォームセクション - 国際化対応版
 */
interface SignInFormSectionProps {
  locale: string;
  username: string;
  password: string;
  onUsernameChange: (value: string) => void;
  onPasswordChange: (value: string) => void;
  onSubmit: (e: React.FormEvent) => void;
  isLoading: boolean;
  error: string;
}

function SignInFormSection({
  locale,
  username,
  password,
  onUsernameChange,
  onPasswordChange,
  onSubmit,
  isLoading,
  error
}: SignInFormSectionProps) {
  const texts = {
    title: locale === 'en' ? 'Sign In' : 'サインイン',
    subtitle: 'Permission-aware RAG System',
    username: locale === 'en' ? 'Username' : 'ユーザー名',
    password: locale === 'en' ? 'Password' : 'パスワード',
    usernamePlaceholder: locale === 'en' ? 'Enter username' : 'ユーザー名を入力',
    passwordPlaceholder: locale === 'en' ? 'Enter password' : 'パスワードを入力',
    signingIn: locale === 'en' ? 'Signing in...' : 'サインイン中...',
    signIn: locale === 'en' ? 'Sign In' : 'サインイン'
  };

  return (
    <div className="w-full lg:w-1/2 flex items-center justify-center p-6 bg-gray-50 h-full">
      <div className="max-w-sm w-full space-y-6">
        <div className="text-center">
          <h2 className="text-2xl font-bold text-gray-900">{texts.title}</h2>
          <p className="mt-2 text-gray-600">{texts.subtitle}</p>
        </div>

        <form onSubmit={onSubmit} className="space-y-4">
          <FormField
            id="username"
            label={texts.username}
            type="text"
            value={username}
            onChange={onUsernameChange}
            placeholder={texts.usernamePlaceholder}
            disabled={isLoading}
            required
          />

          <FormField
            id="password"
            label={texts.password}
            type="password"
            value={password}
            onChange={onPasswordChange}
            placeholder={texts.passwordPlaceholder}
            disabled={isLoading}
            required
          />

          {error && (
            <div className="text-red-600 text-sm text-center" role="alert">
              {error}
            </div>
          )}

          <button
            type="submit"
            disabled={isLoading}
            className="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
          >
            {isLoading ? texts.signingIn : texts.signIn}
          </button>
        </form>
      </div>
    </div>
  );
}

/**
 * 再利用可能なフォームフィールドコンポーネント
 */
interface FormFieldProps {
  id: string;
  label: string;
  type: string;
  value: string;
  onChange: (value: string) => void;
  placeholder?: string;
  disabled?: boolean;
  required?: boolean;
}

function FormField({
  id,
  label,
  type,
  value,
  onChange,
  placeholder,
  disabled = false,
  required = false
}: FormFieldProps) {
  return (
    <div>
      <label htmlFor={id} className="block text-sm font-medium text-gray-700">
        {label}
      </label>
      <input
        id={id}
        type={type}
        value={value}
        onChange={(e) => onChange(e.target.value)}
        className="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 transition-colors text-gray-800 placeholder-gray-400 bg-gray-50 focus:bg-white"
        placeholder={placeholder}
        disabled={disabled}
        required={required}
      />
    </div>
  );
}
