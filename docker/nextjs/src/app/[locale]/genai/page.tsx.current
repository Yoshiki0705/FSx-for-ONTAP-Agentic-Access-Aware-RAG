  // Available Agent IDs (example list)
  const availableAgents = [
    { id: 'AGENT001', name: 'General Assistant Agent', description: 'Multi-purpose conversational agent' },
    { id: 'AGENT002', name: 'Technical Support Agent', description: 'Specialized in technical documentation' },
    { id: 'AGENT003', name: 'Research Agent', description: 'Optimized for research and analysis' },
    { id: 'CUSTOM', name: t('agent.id.custom'), description: 'Enter custom Agent ID' }
  ]

  // Provider list for filtering
  const providers = [
    { value: 'all', label: t('filter.allProviders') },
    { value: 'Anthropic', label: 'Anthropic' },
    { value: 'Amazon', label: 'Amazon' },
    { value: 'Meta', label: 'Meta' },
    { value: 'Mistral AI', label: 'Mistral AI' },
    { value: 'AI21 Labs', label: 'AI21 Labs' },
    { value: 'Cohere', label: 'Cohere' },
    { value: 'Stability AI', label: 'Stability AI' }
  ]
  
  // Calculate model statistics for current region and mode
  const getModelStats = () => {
    const currentRegion = regions.find(r => r.id === region)
    
    // Filter models based on current region and mode
    const regionModels = models.filter(m => m.regions.includes(region))
    const modeCompatibleModels = regionModels.filter(m => 
      mode === 'agent' ? m.agentSupported : m.kbSupported
    )
    
    const availableModels = modeCompatibleModels.length
    const totalRegionModels = regionModels.length
    const unavailableModels = totalRegionModels - availableModels
    
    // Calculate provider-specific stats for current mode and region
    const providerStats = providers.slice(1).map(provider => {
      const providerModels = regionModels.filter(m => m.provider === provider.value)
      const availableCount = providerModels.filter(m => 
        mode === 'agent' ? m.agentSupported : m.kbSupported
      ).length
      const totalCount = providerModels.length
      const unavailableCount = totalCount - availableCount
      
      return {
        provider: provider.label,
        available: availableCount,
        unavailable: unavailableCount,
        total: totalCount
      }
    }).filter(stat => stat.total > 0)
    
    return {
      total: totalRegionModels,
      available: availableModels,
      unavailable: unavailableModels,
      bedrockAvailable: currentRegion?.bedrock || false,
      providerStats,
      mode: mode
    }
  }

  // Filter models based on search, provider filter, region, and mode
  const filteredModels = models.filter(m => {
    const matchesSearch = modelSearch === '' || 
      m.name.toLowerCase().includes(modelSearch.toLowerCase()) ||
      m.provider.toLowerCase().includes(modelSearch.toLowerCase()) ||
      m.category.toLowerCase().includes(modelSearch.toLowerCase())
    
    const matchesProvider = modelFilter === 'all' || m.provider === modelFilter
    const matchesRegion = m.regions.includes(region)
    const matchesMode = mode === 'agent' ? m.agentSupported : m.kbSupported
    
    return matchesSearch && matchesProvider && matchesRegion && matchesMode
  })

  // Group models by provider
  const modelsByProvider = filteredModels.reduce((acc, model) => {
    if (!acc[model.provider]) {
      acc[model.provider] = []
    }
    acc[model.provider].push(model)
    return acc
  }, {} as Record<string, typeof models>)

  // Toggle provider collapse
  const toggleProvider = (provider: string) => {
    const newCollapsed = new Set(collapsedProviders)
    if (newCollapsed.has(provider)) {
      newCollapsed.delete(provider)
    } else {
      newCollapsed.add(provider)
    }
    setCollapsedProviders(newCollapsed)
  }



  // Send message function
  const sendMessage = async () => {
    if (!input.trim() || isLoading) return
    if (mode === 'agent' && !agentId) return

    // セッションが存在しない場合は作成
    let currentSessionId = activeSessionId
    if (!currentSessionId) {
      const firstMessage = input.trim().substring(0, 50)
      const sessionTitle = firstMessage.length < 50 ? firstMessage : `${firstMessage}...`
      
      currentSessionId = createSession({
        title: sessionTitle,
        messages: [],
        mode,
        model,
        region,
        agentId: mode === 'agent' ? agentId : undefined
      })
      
      console.log('[ChatbotPage] Created new session:', currentSessionId)
    }
    
    // Use useChatHistory's addMessage
    addMessage({
      role: 'user',
      content: input.trim()
    })

    setInput('')
    setIsLoading(true)

    try {
      const endpoint = mode === 'agent' ? '/api/bedrock/agent' : '/api/bedrock/chat'
      const requestBody = mode === 'agent' 
        ? {
            message: input.trim(),
            agentId: agentId,
            sessionId: `session-${Date.now()}`
          }
        : {
            message: input.trim(),
            model: model,
            region: region,
            mode: mode,
            settings: settings
          }

      const response = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(requestBody)
      })

      const data = await response.json()
      
      if (data.success) {
        addMessage({
          role: 'assistant',
          content: data.response || data.answer
        })
      } else {
        addMessage({
          role: 'assistant',
          content: 'エラーが発生しました。もう一度お試しください。'
        })
      }
    } catch (error) {
      addMessage({
        role: 'assistant',
        content: 'ネットワークエラーが発生しました。接続を確認してください。'
      })
    } finally {
      setIsLoading(false)
    }
  }

  // Handle new chat
  const handleNewChat = () => {
    setActiveSession(null)
    clearHistory()
    setInput('')
    console.log('[ChatbotPage] Started new chat')
  }

  // Handle Enter key
  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault()
      sendMessage()
    }
  }

  // Get current region and model
  const currentRegion = regions.find(r => r.id === region)
  const currentModel = models.find(m => m.id === model)
  const modelStats = getModelStats()

  return (
    <div style={{ 
      display: 'flex', 
      height: '100vh', 
      fontFamily: '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif',
      backgroundColor: '#f5f5f5'
    }}>
      {/* Enhanced Rich Sidebar */}
      {sidebarOpen && (
        <div style={{ 
          width: '400px', 
          backgroundColor: 'white', 
          borderRight: '1px solid #e0e0e0',
          padding: '24px',
          overflowY: 'auto',
          boxShadow: '2px 0 8px rgba(0,0,0,0.1)'
        }}>
          {/* Header with Language Switcher */}
          <div style={{ marginBottom: '32px' }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start' }}>
              <div>
                <h1 style={{ 
                  margin: '0 0 8px 0', 
                  fontSize: '24px', 
                  fontWeight: '700',
                  color: '#1a1a1a'
                }}>
                  🤖 Permission-aware RAG
                </h1>
                <p style={{ 
                  margin: 0, 
                  fontSize: '14px',
                  color: '#666',
                  lineHeight: '1.4'
                }}>
                  Amazon FSx for NetApp ONTAP
                </p>
              </div>
              
              {/* Language Switcher Buttons */}
              <div style={{ display: 'flex', gap: '4px' }}>
                <button
                  onClick={() => setLanguage('ja')}
                  style={{
                    padding: '6px 12px',
                    border: language === 'ja' ? '2px solid #007bff' : '1px solid #ddd',
                    borderRadius: '6px',
                    backgroundColor: language === 'ja' ? '#007bff' : 'white',
                    color: language === 'ja' ? 'white' : '#333',
                    cursor: 'pointer',
                    fontSize: '12px',
                    fontWeight: '600',
                    transition: 'all 0.2s ease'
                  }}
                  title="日本語に切り替え"
                >
                  🇯🇵 JA
                </button>
                <button
                  onClick={() => setLanguage('en')}
                  style={{
                    padding: '6px 12px',
                    border: language === 'en' ? '2px solid #007bff' : '1px solid #ddd',
                    borderRadius: '6px',
                    backgroundColor: language === 'en' ? '#007bff' : 'white',
                    color: language === 'en' ? 'white' : '#333',
                    cursor: 'pointer',
                    fontSize: '12px',
                    fontWeight: '600',
                    transition: 'all 0.2s ease'
                  }}
                  title="Switch to English"
                >
                  🇺🇸 EN
                </button>
              </div>
            </div>
          </div>

          {/* Mode Switcher */}
          <div style={{ marginBottom: '32px' }}>
            <h3 style={{ 
              margin: '0 0 16px 0', 
              fontSize: '16px', 
              fontWeight: '600',
              color: '#333'
            }}>
              🔄 {language === 'ja' ? 'モード選択' : 'Mode Selection'}
            </h3>
            <div style={{ display: 'flex', gap: '8px' }}>
              <button
                onClick={() => setMode('agent')}
                style={{
                  flex: 1,
                  padding: '12px 16px',
                  border: mode === 'agent' ? '2px solid #007bff' : '1px solid #ddd',
                  borderRadius: '8px',
                  backgroundColor: mode === 'agent' ? '#007bff' : 'white',
                  color: mode === 'agent' ? 'white' : '#333',
                  cursor: 'pointer',
                  fontWeight: '600',
                  transition: 'all 0.2s ease'
                }}
              >
                {t('mode.agent')}
              </button>
              <button
                onClick={() => setMode('kb')}
                style={{
                  flex: 1,
                  padding: '12px 16px',
                  border: mode === 'kb' ? '2px solid #007bff' : '1px solid #ddd',
                  borderRadius: '8px',
                  backgroundColor: mode === 'kb' ? '#007bff' : 'white',
                  color: mode === 'kb' ? 'white' : '#333',
                  cursor: 'pointer',
                  fontWeight: '600',
                  transition: 'all 0.2s ease'
                }}
              >
                {t('mode.kb')}
              </button>
            </div>
          </div>

          {/* Enhanced Region Selection with Dynamic Model Statistics */}
          <div style={{ marginBottom: '32px' }}>
            <h3 style={{ 
              margin: '0 0 16px 0', 
              fontSize: '16px', 
              fontWeight: '600',
              color: '#333'
            }}>
              {t('region.select')}
            </h3>
            <select
              value={region}
              onChange={(e) => setRegion(e.target.value)}
              style={{
                width: '100%',
                padding: '12px 16px',
                border: '1px solid #ddd',
                borderRadius: '8px',
                fontSize: '14px',
                backgroundColor: 'white',
                cursor: 'pointer'
              }}
            >
              {regions.map(r => (
                <option key={r.id} value={r.id}>
                  {r.name}
                </option>
              ))}
            </select>
            
            {/* Enhanced Model Statistics Display - Dynamic by Region and Mode */}
            <div style={{ 
              marginTop: '12px', 
              padding: '16px',
              backgroundColor: '#f8f9fa',
              borderRadius: '8px',
              border: '1px solid #e0e0e0'
            }}>
              <div style={{ 
                display: 'flex', 
                justifyContent: 'space-between', 
                alignItems: 'center',
                marginBottom: '12px'
              }}>
                <div style={{ fontSize: '14px', fontWeight: '600', color: '#333' }}>
                  {modelStats.bedrockAvailable ? '✅ ' + t('region.bedrock.available') : '⚠️ ' + t('region.bedrock.unavailable')}
                </div>
                <div style={{ fontSize: '12px', color: '#666' }}>
                  {t('mode.compatibility.note')}
                </div>
              </div>
              
              {/* Overall Model Statistics for Current Mode */}
              <div style={{ 
                display: 'grid', 
                gridTemplateColumns: '1fr 1fr 1fr', 
                gap: '8px',
                marginBottom: '16px'
              }}>
                <div style={{ 
                  textAlign: 'center',
                  padding: '8px',
                  backgroundColor: '#e8f5e8',
                  borderRadius: '6px',
                  border: '1px solid #4caf50'
                }}>
                  <div style={{ fontSize: '18px', fontWeight: '700', color: '#2e7d32' }}>
                    {modelStats.available}
                  </div>
                  <div style={{ fontSize: '11px', color: '#2e7d32' }}>
                    {mode === 'agent' ? 'Agent対応' : 'KB対応'}
                  </div>
                </div>
                <div style={{ 
                  textAlign: 'center',
                  padding: '8px',
                  backgroundColor: '#ffebee',
                  borderRadius: '6px',
                  border: '1px solid #f44336'
                }}>
                  <div style={{ fontSize: '18px', fontWeight: '700', color: '#c62828' }}>
                    {modelStats.unavailable}
                  </div>
                  <div style={{ fontSize: '11px', color: '#c62828' }}>
                    {mode === 'agent' ? 'Agent非対応' : 'KB非対応'}
                  </div>
                </div>
                <div style={{ 
                  textAlign: 'center',
                  padding: '8px',
                  backgroundColor: '#e3f2fd',
                  borderRadius: '6px',
                  border: '1px solid #2196f3'
                }}>
                  <div style={{ fontSize: '18px', fontWeight: '700', color: '#1565c0' }}>
                    {modelStats.total}
                  </div>
                  <div style={{ fontSize: '11px', color: '#1565c0' }}>
                    リージョン総数
                  </div>
                </div>
              </div>
              
              {/* Provider-specific Statistics for Current Mode */}
              <div style={{ fontSize: '12px', color: '#666' }}>
                <div style={{ fontWeight: '600', marginBottom: '8px' }}>
                  {language === 'ja' ? `${mode === 'agent' ? 'Agent' : 'KB'}モード対応状況:` : `${mode === 'agent' ? 'Agent' : 'KB'} Mode Support:`}
                </div>
                <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '4px' }}>
                  {modelStats.providerStats.map(stat => (
                    <div key={stat.provider} style={{ 
                      fontSize: '11px',
                      padding: '4px 8px',
                      backgroundColor: 'white',
                      borderRadius: '4px',
                      border: '1px solid #e0e0e0'
                    }}>
                      <div style={{ fontWeight: '600' }}>{stat.provider}</div>
                      <div>✅ {stat.available} / ❌ {stat.unavailable}</div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>

          {/* Agent ID Selection (Agent Mode Only) */}
          {mode === 'agent' && (
            <div style={{ marginBottom: '32px' }}>
              <h3 style={{ 
                margin: '0 0 16px 0', 
                fontSize: '16px', 
                fontWeight: '600',
                color: '#333'
              }}>
                {t('agent.select')}
              </h3>
              <select
                value={agentId}
                onChange={(e) => setAgentId(e.target.value)}
                style={{
                  width: '100%',
                  padding: '12px 16px',
                  border: '1px solid #ddd',
                  borderRadius: '8px',
                  fontSize: '14px',
                  backgroundColor: 'white',
                  cursor: 'pointer'
                }}
              >
                <option value="">{t('agent.id.placeholder')}</option>
                {availableAgents.map(agent => (
                  <option key={agent.id} value={agent.id}>
                    {agent.name}
                  </option>
                ))}
              </select>
              
              {/* Custom Agent ID Input */}
              {agentId === 'CUSTOM' && (
                <input
                  type="text"
                  placeholder="Enter custom Agent ID..."
                  style={{
                    width: '100%',
                    padding: '12px 16px',
                    border: '1px solid #ddd',
                    borderRadius: '8px',
                    fontSize: '14px',
                    backgroundColor: 'white',
                    marginTop: '8px'
                  }}
                  onChange={(e) => setAgentId(e.target.value)}
                />
              )}
              
              {/* Agent Information Display */}
              {agentId && agentId !== 'CUSTOM' && (
                <div style={{ 
                  marginTop: '12px', 
                  padding: '12px',
                  backgroundColor: '#e3f2fd',
                  borderRadius: '6px',
                  border: '1px solid #2196f3'
                }}>
                  <div style={{ fontSize: '12px', color: '#1565c0' }}>
                    <div><strong>Agent ID:</strong> {agentId}</div>
                    <div><strong>Description:</strong> {availableAgents.find(a => a.id === agentId)?.description}</div>
                  </div>
                </div>
              )}
            </div>
          )}

          {/* Enhanced Model Selection with Mode-aware Filtering */}
          <div style={{ marginBottom: '32px' }}>
            <h3 style={{ 
              margin: '0 0 16px 0', 
              fontSize: '16px', 
              fontWeight: '600',
              color: '#333'
            }}>
              {t('model.select')} ({mode === 'agent' ? 'Agent対応' : 'KB対応'})
            </h3>
            
            {/* Model Search */}
            <div style={{ marginBottom: '16px' }}>
              <input
                type="text"
                placeholder={t('search.placeholder')}
                value={modelSearch}
                onChange={(e) => setModelSearch(e.target.value)}
                style={{
                  width: '100%',
                  padding: '10px 12px',
                  border: '1px solid #ddd',
                  borderRadius: '6px',
                  fontSize: '14px',
                  backgroundColor: 'white'
                }}
              />
            </div>
            
            {/* Provider Filter */}
            <div style={{ marginBottom: '16px' }}>
              <select
                value={modelFilter}
                onChange={(e) => setModelFilter(e.target.value)}
                style={{
                  width: '100%',
                  padding: '10px 12px',
                  border: '1px solid #ddd',
                  borderRadius: '6px',
                  fontSize: '14px',
                  backgroundColor: 'white',
                  cursor: 'pointer'
                }}
              >
                {providers.map(p => (
                  <option key={p.value} value={p.value}>
                    {p.label}
                  </option>
                ))}
              </select>
            </div>
            
            {/* Provider-based Model Groups - Mode and Region Aware */}
            <div style={{ maxHeight: '300px', overflowY: 'auto', border: '1px solid #e0e0e0', borderRadius: '8px' }}>
              {Object.entries(modelsByProvider).map(([provider, providerModels]) => (
                <div key={provider} style={{ borderBottom: '1px solid #f0f0f0' }}>
                  {/* Provider Header - Collapsible */}
                  <button
                    onClick={() => toggleProvider(provider)}
                    style={{
                      width: '100%',
                      padding: '12px 16px',
                      backgroundColor: '#f8f9fa',
                      border: 'none',
                      textAlign: 'left',
                      cursor: 'pointer',
                      fontSize: '14px',
                      fontWeight: '600',
                      color: '#495057',
                      display: 'flex',
                      justifyContent: 'space-between',
                      alignItems: 'center'
                    }}
                  >
                    <span>{provider} ({providerModels.length})</span>
                    <span style={{ 
                      transform: collapsedProviders.has(provider) ? 'rotate(-90deg)' : 'rotate(0deg)',
                      transition: 'transform 0.2s ease'
                    }}>
                      ▼
                    </span>
                  </button>
                  
                  {/* Provider Models - Collapsible Content */}
                  {!collapsedProviders.has(provider) && (
                    <div style={{ backgroundColor: 'white' }}>
                      {providerModels.map(m => (
                        <button
                          key={m.id}
                          onClick={() => setModel(m.id)}
                          style={{
                            width: '100%',
                            padding: '12px 16px',
                            border: 'none',
                            borderBottom: '1px solid #f0f0f0',
                            backgroundColor: model === m.id ? '#e3f2fd' : 'white',
                            textAlign: 'left',
                            cursor: 'pointer',
                            fontSize: '13px',
                            transition: 'all 0.2s ease'
                          }}
                          onMouseOver={(e) => {
                            if (model !== m.id) {
                              e.currentTarget.style.backgroundColor = '#f5f5f5'
                            }
                          }}
                          onMouseOut={(e) => {
                            if (model !== m.id) {
                              e.currentTarget.style.backgroundColor = 'white'
                            }
                          }}
                        >
                          <div style={{ fontWeight: '600', color: '#333', marginBottom: '4px' }}>
                            ✅ {m.name}
                          </div>
                          <div style={{ fontSize: '11px', color: '#666' }}>
                            {m.category} • {m.contextLength} • {mode === 'agent' ? 'Agent対応' : 'KB対応'}
                          </div>
                        </button>
                      ))}
                    </div>
                  )}
                </div>
              ))}
            </div>
            
            {/* Current Model Info */}
            <div style={{ 
              marginTop: '12px', 
              fontSize: '12px', 
              color: '#666',
              padding: '8px 12px',
              backgroundColor: '#f8f9fa',
              borderRadius: '6px'
            }}>
              <div><strong>Selected:</strong> {currentModel?.name || 'Unknown'}</div>
              <div><strong>Provider:</strong> {currentModel?.provider || 'Unknown'}</div>
              <div><strong>Category:</strong> {currentModel?.category || 'Unknown'}</div>
              <div><strong>Mode Support:</strong> {mode === 'agent' ? 'Agent ✅' : 'KB ✅'}</div>
            </div>
          </div>

          {/* Mode-specific Information Panel with Agent ID */}
          <div style={{ marginBottom: '32px' }}>
            <div style={{
              padding: '16px',
              backgroundColor: mode === 'agent' ? '#e3f2fd' : '#e8f5e8',
              borderRadius: '8px',
              border: `1px solid ${mode === 'agent' ? '#1976d2' : '#4caf50'}`
            }}>
              <h4 style={{ 
                margin: '0 0 12px 0', 
                fontSize: '14px', 
                fontWeight: '600',
                color: mode === 'agent' ? '#1976d2' : '#388e3c'
              }}>
                {mode === 'agent' ? t('agent.info') : t('kb.info')}
              </h4>
              <div style={{ fontSize: '12px', color: '#666', lineHeight: '1.4' }}>
                {mode === 'agent' ? (
                  <>
                    <div><strong>Status:</strong> {agentId ? '✅ READY' : '⚠️ AGENT ID REQUIRED'}</div>
                    <div><strong>Agent ID:</strong> {agentId || 'Not selected'}</div>
                    <div><strong>Model:</strong> {currentModel?.name}</div>
                    <div><strong>Region:</strong> {currentRegion?.name}</div>
                    <div><strong>Features:</strong> Multi-step reasoning, Dynamic context, Document search</div>
                  </>
                ) : (
                  <>
                    <div><strong>Status:</strong> 📚 READY</div>
                    <div><strong>Model:</strong> {currentModel?.name}</div>
                    <div><strong>Region:</strong> {currentRegion?.name}</div>
                    <div><strong>Features:</strong> Vector search, Semantic matching, Document retrieval</div>
                  </>
                )}
              </div>
            </div>
          </div>

          {/* Create Agent Button (Agent Mode Only) */}
          {mode === 'agent' && (
            <div style={{ marginBottom: '32px' }}>
              <button
                onClick={() => {
                  alert(language === 'ja' ? 
                    '🚀 新しいAgent作成機能は開発中です。\n\n今後のロードマップ:\n• カスタムAgent作成\n• 専門知識の注入\n• パーソナライゼーション\n• マルチモーダル対応' :
                    '🚀 New Agent creation feature is under development.\n\nUpcoming roadmap:\n• Custom Agent creation\n• Knowledge injection\n• Personalization\n• Multimodal support'
                  )
                }}
                style={{
                  width: '100%',
                  padding: '16px 20px',
                  backgroundColor: '#ff6b35',
                  color: 'white',
                  border: 'none',
                  borderRadius: '8px',
                  fontSize: '16px',
                  fontWeight: '600',
                  cursor: 'pointer',
                  boxShadow: '0 4px 12px rgba(255, 107, 53, 0.3)',
                  transition: 'all 0.2s ease'
                }}
                onMouseOver={(e) => {
                  e.currentTarget.style.backgroundColor = '#e55a2b'
                  e.currentTarget.style.transform = 'translateY(-2px)'
                }}
                onMouseOut={(e) => {
                  e.currentTarget.style.backgroundColor = '#ff6b35'
                  e.currentTarget.style.transform = 'translateY(0px)'
                }}
              >
                {t('agent.create')}
              </button>
            </div>
          )}

          {/* Session List Section */}
          <div style={{
            borderTop: '1px solid #e0e0e0',
            paddingTop: '16px',
            marginTop: '16px',
            marginBottom: '24px'
          }}>
            <div style={{
              fontSize: '14px',
              fontWeight: '600',
              marginBottom: '12px',
              color: '#333',
              display: 'flex',
              justifyContent: 'space-between',
              alignItems: 'center'
            }}>
              <span>💬 {language === 'ja' ? 'チャット履歴' : 'Chat History'}</span>
              <button
                onClick={handleNewChat}
                style={{
                  padding: '4px 12px',
                  fontSize: '12px',
                  backgroundColor: '#007bff',
                  color: 'white',
                  border: 'none',
                  borderRadius: '6px',
                  cursor: 'pointer',
                  transition: 'background-color 0.2s'
                }}
                onMouseEnter={(e) => e.currentTarget.style.backgroundColor = '#0056b3'}
                onMouseLeave={(e) => e.currentTarget.style.backgroundColor = '#007bff'}
              >
                ＋ {language === 'ja' ? '新規' : 'New'}
              </button>
            </div>
            <SessionList />
          </div>

          {/* Chat History Settings Section */}
          <div style={{
            borderTop: '1px solid #e0e0e0',
            paddingTop: '16px',
            marginTop: '16px',
            marginBottom: '24px'
          }}>
            <div style={{
              fontSize: '14px',
              fontWeight: '600',
              marginBottom: '12px',
              color: '#333'
            }}>
              💾 {language === 'ja' ? 'チャット履歴保存設定' : 'Chat History Save Settings'}
            </div>
            
            {/* Auto-save toggle with description */}
            <div style={{
              display: 'flex',
              justifyContent: 'space-between',
              alignItems: 'center',
              marginBottom: '8px'
            }}>
              <div>
                <div style={{ fontSize: '13px', color: '#333', marginBottom: '4px' }}>
                  {language === 'ja' ? '自動保存' : 'Auto Save'}
                </div>
                <div style={{ fontSize: '11px', color: '#666' }}>
                  {language === 'ja' 
                    ? 'チャット履歴を自動的に保存します' 
                    : 'Automatically save chat history'
                  }
                </div>
              </div>
              <label style={{ 
                position: 'relative',
                display: 'inline-block',
                width: '44px',
                height: '24px'
              }}>
                <input
                  type="checkbox"
                  checked={chatSettings.autoSave}
                  onChange={(e) => updateChat({ autoSave: e.target.checked })}
                  style={{ opacity: 0, width: 0, height: 0 }}
                />
                <span style={{
                  position: 'absolute',
                  cursor: 'pointer',
                  top: 0,
                  left: 0,
                  right: 0,
                  bottom: 0,
                  backgroundColor: chatSettings.autoSave ? '#007bff' : '#ccc',
                  transition: '0.4s',
                  borderRadius: '24px'
                }}>
                  <span style={{
                    position: 'absolute',
                    content: '',
                    height: '18px',
                    width: '18px',
                    left: chatSettings.autoSave ? '23px' : '3px',
                    bottom: '3px',
                    backgroundColor: 'white',
                    transition: '0.4s',
                    borderRadius: '50%'
                  }} />
                </span>
              </label>
            </div>
            
            {/* Auto-save status indicator */}
            {chatSettings.autoSave && (
              <div style={{
                display: 'flex',
                alignItems: 'center',
                gap: '8px',
                marginTop: '8px',
                padding: '8px 12px',
                backgroundColor: '#f8f9fa',
                borderRadius: '6px',
                border: '1px solid #e0e0e0'
              }}>
                <AutoSaveIndicator
                  status={saveStatus}
                  lastSavedAt={lastSavedAt}
                />
              </div>
            )}
          </div>

          {/* Enhanced Advanced Settings - Moved to Bottom */}
          <div style={{ marginBottom: '0' }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '16px' }}>
              <h3 style={{ 
                margin: 0, 
                fontSize: '16px', 
                fontWeight: '600',
                color: '#333'
              }}>
                {t('settings.advanced')}
              </h3>
              <button
                onClick={() => setShowAdvancedSettings(!showAdvancedSettings)}
                style={{
                  padding: '4px 12px',
                  border: '1px solid #ddd',
                  borderRadius: '6px',
                  backgroundColor: 'white',
                  cursor: 'pointer',
                  fontSize: '12px',
                  color: '#666'
                }}
              >
                {showAdvancedSettings ? '非表示' : '表示'}
              </button>
            </div>
            
            {/* Collapsible Advanced Settings */}
            {showAdvancedSettings && (
              <div style={{ 
                padding: '16px',
                backgroundColor: '#f8f9fa',
                borderRadius: '8px',
                border: '1px solid #e0e0e0'
              }}>
                <div style={{ marginBottom: '20px' }}>
                  <label style={{ 
                    display: 'block', 
                    marginBottom: '8px', 
                    fontSize: '14px',
                    fontWeight: '600',
                    color: '#555'
                  }}>
                    {t('settings.temperature')}: {settings.temperature}
                  </label>
                  <input
                    type="range"
                    min="0"
                    max="1"
                    step="0.1"
                    value={settings.temperature}
                    onChange={(e) => setSettings(prev => ({ ...prev, temperature: parseFloat(e.target.value) }))}
                    style={{ 
                      width: '100%',
                      height: '6px',
                      borderRadius: '3px',
                      background: '#ddd',
                      outline: 'none'
                    }}
                  />
                  <div style={{ fontSize: '12px', color: '#666', marginTop: '4px' }}>
                    {t('settings.creativity')}: {settings.temperature < 0.3 ? '低' : settings.temperature < 0.7 ? '中' : '高'}
                  </div>
                </div>

                <div style={{ marginBottom: '20px' }}>
                  <label style={{ 
                    display: 'block', 
                    marginBottom: '8px', 
                    fontSize: '14px',
                    fontWeight: '600',
                    color: '#555'
                  }}>
                    {t('settings.maxTokens')}: {settings.maxTokens}
                  </label>
                  <input
                    type="range"
                    min="100"
                    max="8000"
                    step="100"
                    value={settings.maxTokens}
                    onChange={(e) => setSettings(prev => ({ ...prev, maxTokens: parseInt(e.target.value) }))}
                    style={{ 
                      width: '100%',
                      height: '6px',
                      borderRadius: '3px',
                      background: '#ddd',
                      outline: 'none'
                    }}
                  />
                  <div style={{ fontSize: '12px', color: '#666', marginTop: '4px' }}>
                    {t('settings.responseLength')}: {settings.maxTokens < 2000 ? '短' : settings.maxTokens < 5000 ? '中' : '長'}
                  </div>
                </div>

                <div style={{ marginBottom: '0' }}>
                  <label style={{ 
                    display: 'block', 
                    marginBottom: '8px', 
                    fontSize: '14px',
                    fontWeight: '600',
                    color: '#555'
                  }}>
                    {t('settings.topP')}: {settings.topP}
                  </label>
                  <input
                    type="range"
                    min="0"
                    max="1"
                    step="0.1"
                    value={settings.topP}
                    onChange={(e) => setSettings(prev => ({ ...prev, topP: parseFloat(e.target.value) }))}
                    style={{ 
                      width: '100%',
                      height: '6px',
                      borderRadius: '3px',
                      background: '#ddd',
                      outline: 'none'
                    }}
                  />
                  <div style={{ fontSize: '12px', color: '#666', marginTop: '4px' }}>
                    {t('settings.diversity')}: {settings.topP < 0.3 ? '低' : settings.topP < 0.7 ? '中' : '高'}
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>
      )}

      {/* Main Chat Area */}
      <div style={{ 
        flex: 1, 
        display: 'flex', 
        flexDirection: 'column',
        backgroundColor: 'white'
      }}>
        {/* Header with Sidebar Toggle */}
        <div style={{ 
          padding: '16px 24px',
          borderBottom: '1px solid #e0e0e0',
          backgroundColor: 'white',
          display: 'flex',
          justifyContent: 'space-between',
          alignItems: 'center'
        }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: '16px' }}>
            <button
              onClick={toggleSidebar}
              style={{
                padding: '8px 12px',
                border: '1px solid #ddd',
                borderRadius: '6px',
                backgroundColor: 'white',
                cursor: 'pointer',
                fontSize: '14px',
                color: '#666'
              }}
            >
              {sidebarOpen ? '◀ 隠す' : '▶ 表示'}
            </button>
            <h2 style={{ 
              margin: 0, 
              fontSize: '20px', 
              fontWeight: '600',
              color: '#333'
            }}>
              {mode === 'agent' ? '🤖 Agent Chat' : '📚 Knowledge Base Chat'}
            </h2>
          </div>
          <div style={{ fontSize: '14px', color: '#666' }}>
            {currentModel?.name} • {currentRegion?.name}
          </div>
        </div>

        {/* Messages Area */}
        <div style={{ 
          flex: 1, 
          overflowY: 'auto',
          padding: '24px',
          backgroundColor: '#fafafa'
        }}>
          {messages.length === 0 ? (
            <div style={{ 
              textAlign: 'center', 
              color: '#666',
              marginTop: '100px'
            }}>
              <div style={{ fontSize: '48px', marginBottom: '16px' }}>
                {mode === 'agent' ? '🤖' : '📚'}
              </div>
              <h3 style={{ margin: '0 0 8px 0', fontSize: '18px', fontWeight: '600' }}>
                {mode === 'agent' ? 
                  (language === 'ja' ? 'Agentとの会話を開始' : 'Start conversation with Agent') :
                  (language === 'ja' ? 'Knowledge Baseに質問' : 'Ask Knowledge Base')
                }
              </h3>
              <p style={{ margin: 0, fontSize: '14px' }}>
                {mode === 'agent' ? 
                  (language === 'ja' ? '下のテキストボックスに質問を入力してください' : 'Type your question in the text box below') :
                  (language === 'ja' ? 'ドキュメントから情報を検索します' : 'Search information from documents')
                }
              </p>
            </div>
          ) : (
            <div style={{ maxWidth: '800px', margin: '0 auto' }}>
              {messages.map((message, index) => (
                <div
                  key={index}
                  style={{
                    marginBottom: '24px',
                    display: 'flex',
                    justifyContent: message.role === 'user' ? 'flex-end' : 'flex-start'
                  }}
                >
                  <div style={{
                    maxWidth: '70%',
                    padding: '16px 20px',
                    borderRadius: '16px',
                    backgroundColor: message.role === 'user' ? '#007bff' : 'white',
                    color: message.role === 'user' ? 'white' : '#333',
                    border: message.role === 'assistant' ? '1px solid #e0e0e0' : 'none',
                    boxShadow: '0 2px 8px rgba(0,0,0,0.1)'
                  }}>
                    <div style={{ 
                      fontSize: '14px', 
                      lineHeight: '1.5',
                      whiteSpace: 'pre-wrap'
                    }}>
                      {message.content}
                    </div>
                    <div style={{ 
                      fontSize: '11px', 
                      opacity: 0.7,
                      marginTop: '8px'
                    }}>
                      {new Date(message.timestamp || Date.now()).toLocaleTimeString('ja-JP', { 
                        hour: '2-digit', 
                        minute: '2-digit' 
                      })}
                    </div>
                  </div>
                </div>
              ))}
              
              {/* Loading indicator */}
              {isLoading && (
                <div style={{
                  marginBottom: '24px',
                  display: 'flex',
                  justifyContent: 'flex-start'
                }}>
                  <div style={{
                    padding: '16px 20px',
                    borderRadius: '16px',
                    backgroundColor: 'white',
                    border: '1px solid #e0e0e0',
                    boxShadow: '0 2px 8px rgba(0,0,0,0.1)'
                  }}>
                    <div style={{ 
                      fontSize: '14px', 
                      color: '#666',
                      display: 'flex',
                      alignItems: 'center',
                      gap: '8px'
                    }}>
                      <div style={{
                        width: '16px',
                        height: '16px',
                        border: '2px solid #f3f3f3',
                        borderTop: '2px solid #007bff',
                        borderRadius: '50%',
                        animation: 'spin 1s linear infinite'
                      }}></div>
                      {t('chat.generating')}
                    </div>
                  </div>
                </div>
              )}
            </div>
          )}
        </div>

        {/* Input Area */}
        <div style={{ 
          padding: '24px',
          borderTop: '1px solid #e0e0e0',
          backgroundColor: 'white'
        }}>
          <div style={{ maxWidth: '800px', margin: '0 auto' }}>
            <div style={{ 
              display: 'flex', 
              gap: '12px',
              alignItems: 'flex-end'
            }}>
              <div style={{ flex: 1 }}>
                <textarea
                  value={input}
                  onChange={(e) => setInput(e.target.value)}
                  onKeyDown={handleKeyDown}
                  placeholder={mode === 'agent' ? t('chat.placeholder.agent') : t('chat.placeholder.kb')}
                  disabled={isLoading || (mode === 'agent' && !agentId)}
                  style={{
                    width: '100%',
                    minHeight: '60px',
                    maxHeight: '120px',
                    padding: '16px 20px',
                    border: '1px solid #ddd',
                    borderRadius: '12px',
                    fontSize: '14px',
                    lineHeight: '1.5',
                    resize: 'vertical',
                    fontFamily: 'inherit',
                    outline: 'none',
                    backgroundColor: (isLoading || (mode === 'agent' && !agentId)) ? '#f5f5f5' : 'white'
                  }}
                />
                <div style={{ 
                  display: 'flex', 
                  justifyContent: 'space-between',
                  alignItems: 'center',
                  marginTop: '8px',
                  fontSize: '12px',
                  color: '#666'
                }}>
                  <div>
                    {t('chat.characters')}: {input.length}
                    {mode === 'agent' && !agentId && (
                      <span style={{ color: '#f44336', marginLeft: '8px' }}>
                        ⚠️ Agent IDが必要です
                      </span>
                    )}
                  </div>
                  <div>
                    Shift + Enter: {language === 'ja' ? '改行' : 'New line'} | Enter: {language === 'ja' ? '送信' : 'Send'}
                  </div>
                </div>
              </div>
              <button
                onClick={sendMessage}
                disabled={!input.trim() || isLoading || (mode === 'agent' && !agentId)}
                style={{
                  padding: '16px 24px',
                  backgroundColor: (!input.trim() || isLoading || (mode === 'agent' && !agentId)) ? '#ccc' : '#007bff',
                  color: 'white',
                  border: 'none',
                  borderRadius: '12px',
                  fontSize: '14px',
                  fontWeight: '600',
                  cursor: (!input.trim() || isLoading || (mode === 'agent' && !agentId)) ? 'not-allowed' : 'pointer',
                  transition: 'all 0.2s ease',
                  minWidth: '80px'
                }}
              >
                {isLoading ? '...' : t('chat.send')}
              </button>
            </div>
          </div>
        </div>
      </div>

      {/* CSS Animation for loading spinner */}
      <style jsx>{`
        @keyframes spin {
          0% { transform: rotate(0deg); }
          100% { transform: rotate(360deg); }
        }
      `}</style>
    </div>
  )
}