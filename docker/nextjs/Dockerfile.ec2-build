# Dockerfile for EC2 Build Copy Method
# This Dockerfile does NOT run npm run build
# Instead, it copies the .next folder from EC2 build

FROM --platform=linux/amd64 public.ecr.aws/docker/library/node:22-slim AS builder
WORKDIR /app

# package.jsonとpackage-lock.jsonのみをコピー
COPY package*.json ./

# 依存関係をインストール
RUN npm install --legacy-peer-deps

# ソースコードをコピー（.nextは後で明示的にコピー）
COPY package*.json ./
COPY public ./public
COPY src ./src
COPY run.sh ./run.sh
COPY i18n.ts ./i18n.ts
COPY next.config.js ./next.config.js
COPY tsconfig.json ./tsconfig.json
COPY tailwind.config.js ./tailwind.config.js
COPY postcss.config.mjs ./postcss.config.mjs

# .nextフォルダを明示的にコピー（standaloneを含む全て）
COPY .next ./.next

# ⚠️ npm run build は実行しない（EC2でビルド済み）

FROM --platform=linux/amd64 public.ecr.aws/docker/library/node:22-slim AS runner
COPY --from=public.ecr.aws/awsguru/aws-lambda-adapter:0.9.0-x86_64 /lambda-adapter /opt/extensions/lambda-adapter

ENV PORT=3000 \
    NODE_ENV=production \
    AWS_LWA_INVOKE_MODE=buffered \
    AWS_LWA_PORT=3000 \
    AWS_LWA_READINESS_CHECK_PATH=/api/health \
    AWS_LWA_READINESS_CHECK_PORT=3000

WORKDIR /app
COPY --from=builder /app/public ./public
COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/src/messages ./src/messages
COPY --from=builder /app/run.sh ./run.sh
COPY --from=builder /app/i18n.ts ./i18n.ts
RUN ln -s /tmp/cache ./.next/cache
RUN chmod +x ./run.sh

CMD exec ./run.sh
