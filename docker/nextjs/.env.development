# ============================================
# ローカル開発用環境変数
# Cognito/AWS不要でミドルウェア認証フローを完全に動作させる
# ============================================
# ⚠️ このファイルはGitHubに公開して問題ない値のみ含みます

NODE_ENV=development

# ---- 認証設定 ----
# COGNITO_CLIENT_ID を設定しないことでローカルデモ認証モードが有効化
# デモユーザー: admin/admin123, developer/dev123, user/user123
JWT_SECRET=local-dev-jwt-secret-not-for-production
CSRF_SECRET=local-dev-csrf-secret-not-for-production

# ---- DynamoDB Local ----
AWS_REGION=ap-northeast-1
SESSION_TABLE_NAME=permission-aware-rag-sessions
DYNAMODB_ENDPOINT=http://localhost:8000
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# ---- Next.js ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- v4.0.0 Feature Flags ----
# ローカル開発時にv4機能のUIを表示するための設定
# 実際のAWS APIは呼び出せないが、UIコンポーネントの確認が可能
VOICE_CHAT_ENABLED=true
GUARDRAILS_ENABLED=true
ENABLE_AGENT_REGISTRY=true
AGENT_REGISTRY_REGION=ap-northeast-1
AGENT_POLICY_ENABLED=true
ENABLE_AGENTCORE_MEMORY=true
EPISODIC_MEMORY_ENABLED=true
SUPERVISOR_AGENT_ID=local-dev-supervisor
