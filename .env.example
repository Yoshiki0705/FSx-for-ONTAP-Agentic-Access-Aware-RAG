# ============================================
# Permission-aware RAG デモ環境 設定ファイル
# ============================================
# このファイルをコピーして .env として使用してください:
#   cp .env.example .env

# ---- AWS アカウント設定 ----
# CDKデプロイ先のAWSアカウントID
CDK_DEFAULT_ACCOUNT=123456789012
# デプロイ先リージョン
CDK_DEFAULT_REGION=ap-northeast-1

# ---- CDK コンテキストパラメータ ----
# プロジェクト名（リソース名のプレフィックスに使用）
PROJECT_NAME=perm-rag-demo
# 環境名
ENVIRONMENT=demo

# ---- ECR設定 ----
# ECRリポジトリ名（Next.jsアプリケーションのDockerイメージ）
ECR_REPOSITORY_NAME=permission-aware-rag-webapp
# デプロイするイメージタグ
IMAGE_TAG=latest

# ---- Cognito設定（デプロイ後に自動設定） ----
# COGNITO_USER_POOL_ID=ap-northeast-1_XXXXXXXXX
# COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Bedrock設定 ----
# 使用するFoundation Model
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
# Embedding Model
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# ---- Next.js アプリケーション設定 ----
NODE_ENV=production
# Lambda Web Adapter ポート
AWS_LWA_PORT=3000
