{
  "projectName": "permission-aware-rag",
  "environment": "prod",
  "agentCore": {
    "enabled": true,
    "runtime": {
      "enabled": true,
      "lambdaConfig": {
        "timeout": 30,
        "memorySize": 2048,
        "reservedConcurrentExecutions": 10,
        "provisionedConcurrentExecutions": 5
      },
      "eventBridgeConfig": {
        "enabled": false
      }
    },
    "gateway": {
      "enabled": true,
      "restApiConversionConfig": {
        "conversionOptions": {
          "autoGenerateToolDefinitions": true
        }
      }
    },
    "memory": {
      "enabled": true,
      "memoryStrategyConfig": {
        "enableSemantic": true,
        "enableSummary": true,
        "enableUserPreference": true
      },
      "kmsConfig": {
        "keyAliasPrefix": "agentcore-memory-prod"
      }
    },
    "identity": {
      "enabled": true,
      "dynamoDbConfig": {
        "readCapacity": 10,
        "writeCapacity": 10,
        "pointInTimeRecovery": true
      },
      "rbacConfig": {
        "defaultRole": "User"
      },
      "abacConfig": {
        "enableDepartmentAttribute": true,
        "enableProjectAttribute": true,
        "enableSensitivityAttribute": true
      }
    },
    "browser": {
      "enabled": false
    },
    "codeInterpreter": {
      "enabled": false
    },
    "observability": {
      "enabled": true,
      "xrayConfig": {
        "samplingRate": 0.1,
        "enableActiveTracing": true
      },
      "cloudWatchConfig": {
        "dashboardName": "AgentCore-Production-Dashboard",
        "logRetentionDays": 30
      },
      "errorTrackingConfig": {
        "enableRootCauseAnalysis": true,
        "errorThreshold": 5
      }
    },
    "evaluations": {
      "enabled": true,
      "qualityMetricsConfig": {
        "enabledMetrics": [
          "accuracy",
          "relevance",
          "helpfulness"
        ],
        "evaluationFrequency": "hourly"
      },
      "abTestConfig": {
        "enableAutoOptimization": true,
        "minSampleSize": 200,
        "confidenceLevel": 0.95
      },
      "performanceEvaluationConfig": {
        "latencyThreshold": 500,
        "throughputThreshold": 200,
        "costThreshold": 50.0
      }
    },
    "policy": {
      "enabled": true,
      "naturalLanguagePolicyConfig": {
        "enableAutoConversion": true,
        "defaultPolicyTemplate": "strict"
      },
      "cedarIntegrationConfig": {
        "enableFormalVerification": true,
        "enableConflictDetection": true
      }
    }
  }
}
