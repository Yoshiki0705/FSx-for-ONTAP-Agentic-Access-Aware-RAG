# OpenSearchドメイン作成設定ファイル
# このファイルをコピーして環境に応じて設定を変更してください

# 基本設定
DOMAIN_NAME="embedding-vector-search"
REGION="ap-northeast-1"
INSTANCE_TYPE="t3.small.search"
INSTANCE_COUNT=1
VOLUME_SIZE=20
MASTER_USER_NAME="embedding_admin"

# 機密情報は環境変数で設定してください
# export OPENSEARCH_MASTER_PASSWORD='your-secure-password'

# プロジェクト設定
PROJECT_NAME="embedding-opensearch-test"
ENVIRONMENT="dev"

# VPC設定（自動検出されますが、必要に応じて指定可能）
# VPC_ID=""
# SUBNET_IDS=""

# セキュリティ設定
ENABLE_FINE_GRAINED_ACCESS_CONTROL=true
ENABLE_ENCRYPTION_AT_REST=true
ENABLE_NODE_TO_NODE_ENCRYPTION=true
ENFORCE_HTTPS=true

# ログ設定
ENABLE_INDEX_SLOW_LOGS=true
ENABLE_SEARCH_SLOW_LOGS=true

# タグ設定
COST_CENTER="ai-research"
OWNER="data-engineering-team"
DATA_CLASSIFICATION="internal"