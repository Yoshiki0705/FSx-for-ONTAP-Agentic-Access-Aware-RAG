# Windows AD FSxN統合環境デプロイメント設定
# このファイルは機密情報を含む可能性があるため、適切に管理してください

# デフォルト設定
DEFAULT_ENVIRONMENT="dev"
DEFAULT_REGION="ap-northeast-1"
DEFAULT_PROFILE="default"

# タイムアウト設定（秒）
STACK_TIMEOUT=3600
VALIDATION_TIMEOUT=300

# S3設定
S3_BUCKET_PREFIX="windows-ad-fsxn"
S3_VERSIONING_ENABLED="true"

# セキュリティ設定
ENABLE_TERMINATION_PROTECTION="true"
ENABLE_ROLLBACK_ON_FAILURE="true"

# 監視設定
ENABLE_DETAILED_MONITORING="true"
NOTIFICATION_ENABLED="false"

# ログ設定
LOG_LEVEL="INFO"
LOG_RETENTION_DAYS=30

# 検証設定
SKIP_PRE_DEPLOYMENT_CHECKS="false"
SKIP_POST_DEPLOYMENT_VALIDATION="false"

# 注意: 機密情報（パスワード、APIキー等）はこのファイルに記載せず、
# AWS Secrets Manager や環境変数を使用してください