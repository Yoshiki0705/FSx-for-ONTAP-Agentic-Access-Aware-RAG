{
  "environment": "staging",
  "region": "ap-northeast-1",
  "projectName": "permission-aware-rag",
  "vpcId": "vpc-xxxxxxxxxxxxxxxxx",
  "availabilityZones": ["ap-northeast-1a", "ap-northeast-1c"],
  
  "networking": {
    "vpcCidr": "10.1.0.0/16",
    "publicSubnetCidrs": ["10.1.1.0/24", "10.1.2.0/24"],
    "privateSubnetCidrs": ["10.1.11.0/24", "10.1.12.0/24"],
    "isolatedSubnetCidrs": ["10.1.21.0/24", "10.1.22.0/24"]
  },

  "security": {
    "enableWaf": true,
    "enableGuardDuty": true,
    "enableSecurityHub": true,
    "kmsKeyRotation": true,
    "sslCertificateArn": "arn:aws:acm:ap-northeast-1:ACCOUNT_ID:certificate/CERT_ID"
  },

  "storage": {
    "s3": {
      "documentsBucket": {
        "versioning": true,
        "encryption": "AES256",
        "lifecycleRules": [
          {
            "id": "DeleteOldVersions",
            "enabled": true,
            "noncurrentVersionExpiration": 90
          }
        ]
      },
      "logsBucket": {
        "versioning": false,
        "encryption": "AES256",
        "lifecycleRules": [
          {
            "id": "DeleteOldLogs",
            "enabled": true,
            "expiration": 90
          }
        ]
      }
    },
    "fsxOntap": {
      "enabled": true,
      "storageCapacity": 1024,
      "throughputCapacity": 128,
      "deploymentType": "MULTI_AZ_1",
      "automaticBackupRetentionDays": 7
    }
  },

  "database": {
    "dynamodb": {
      "billingMode": "PAY_PER_REQUEST",
      "pointInTimeRecovery": true,
      "encryption": "AWS_MANAGED"
    },
    "opensearch": {
      "enabled": true,
      "instanceType": "t3.small.search",
      "instanceCount": 2,
      "volumeSize": 100,
      "volumeType": "gp3",
      "encryptionAtRest": true,
      "nodeToNodeEncryption": true
    }
  },

  "compute": {
    "lambda": {
      "runtime": "nodejs20.x",
      "timeout": 300,
      "memorySize": 1024,
      "reservedConcurrentExecutions": 10,
      "environment": {
        "LOG_LEVEL": "INFO",
        "NODE_ENV": "staging"
      }
    }
  },

  "agentCore": {
    "runtime": {
      "enabled": true,
      "timeout": 300,
      "memory": 1024,
      "reservedConcurrency": 5,
      "environment": {
        "LOG_LEVEL": "INFO"
      }
    },
    "gateway": {
      "enabled": true,
      "timeout": 300,
      "memory": 1024,
      "reservedConcurrency": 5,
      "restApiConversion": {
        "enabled": true,
        "maxRetries": 3,
        "timeout": 30000
      },
      "lambdaConversion": {
        "enabled": true,
        "maxRetries": 3
      },
      "mcpIntegration": {
        "enabled": true,
        "servers": []
      }
    },
    "memory": {
      "enabled": true,
      "timeout": 300,
      "memory": 1024,
      "reservedConcurrency": 5,
      "retentionDays": 30,
      "strategies": ["lastKTurns", "longTermMemory"],
      "shortTermMemory": {
        "maxTurns": 10,
        "ttl": 3600
      },
      "longTermMemory": {
        "enabled": true,
        "indexName": "agent-memory-staging"
      }
    },
    "browser": {
      "enabled": true,
      "timeout": 900,
      "memory": 2048,
      "reservedConcurrency": 3,
      "puppeteer": {
        "headless": true,
        "defaultViewport": {
          "width": 1920,
          "height": 1080
        }
      },
      "s3Storage": {
        "bucketName": "agentcore-browser-staging",
        "prefix": "screenshots/"
      }
    },
    "codeInterpreter": {
      "enabled": true,
      "timeout": 900,
      "memory": 2048,
      "reservedConcurrency": 3,
      "sessionManagement": {
        "maxSessions": 100,
        "sessionTimeout": 3600,
        "cleanupInterval": 300
      },
      "allowedPackages": [
        "numpy",
        "pandas",
        "matplotlib",
        "scikit-learn",
        "scipy",
        "requests",
        "beautifulsoup4",
        "pillow"
      ],
      "securityRestrictions": {
        "networkAccess": false,
        "fileSystemAccess": "restricted",
        "maxExecutionTime": 300
      }
    },
    "identity": {
      "enabled": true,
      "timeout": 300,
      "memory": 512,
      "reservedConcurrency": 10,
      "rbacEnabled": true,
      "abacEnabled": true,
      "dynamodbTable": {
        "tableName": "agentcore-identity-staging",
        "billingMode": "PAY_PER_REQUEST"
      },
      "defaultRoles": ["user", "developer", "admin"],
      "defaultPolicies": [
        {
          "name": "ReadOnlyAccess",
          "effect": "Allow",
          "actions": ["s3:GetObject", "dynamodb:GetItem"],
          "resources": ["*"]
        }
      ]
    },
    "policy": {
      "enabled": true,
      "timeout": 300,
      "memory": 512,
      "reservedConcurrency": 5,
      "naturalLanguageEnabled": true,
      "cedarEnabled": true,
      "dynamodbTable": {
        "tableName": "agentcore-policy-staging",
        "billingMode": "PAY_PER_REQUEST"
      },
      "policyValidation": {
        "enabled": true,
        "strictMode": false
      },
      "conflictDetection": {
        "enabled": true,
        "autoResolve": false
      }
    },
    "observability": {
      "enabled": true,
      "timeout": 300,
      "memory": 512,
      "reservedConcurrency": 5,
      "xrayEnabled": true,
      "customMetricsEnabled": true,
      "cloudwatchDashboard": {
        "enabled": true,
        "dashboardName": "AgentCore-Staging-Dashboard"
      },
      "alarms": {
        "enabled": true,
        "errorRateThreshold": 5,
        "latencyThreshold": 3000,
        "snsTopicArn": "arn:aws:sns:ap-northeast-1:ACCOUNT_ID:agentcore-staging-alarms"
      }
    },
    "evaluations": {
      "enabled": true,
      "timeout": 300,
      "memory": 1024,
      "reservedConcurrency": 3,
      "qualityMetricsEnabled": true,
      "abTestEnabled": true,
      "dynamodbTable": {
        "tableName": "agentcore-evaluations-staging",
        "billingMode": "PAY_PER_REQUEST"
      },
      "s3Storage": {
        "bucketName": "agentcore-evaluations-staging",
        "prefix": "results/"
      },
      "metrics": {
        "accuracy": {
          "enabled": true,
          "threshold": 0.9
        },
        "latency": {
          "enabled": true,
          "threshold": 2000
        },
        "errorRate": {
          "enabled": true,
          "threshold": 0.05
        }
      }
    }
  },

  "monitoring": {
    "cloudwatch": {
      "logRetentionDays": 30,
      "metricsEnabled": true
    },
    "xray": {
      "enabled": true,
      "samplingRate": 0.1
    },
    "alarms": {
      "enabled": true,
      "snsTopicArn": "arn:aws:sns:ap-northeast-1:ACCOUNT_ID:monitoring-staging"
    }
  },

  "tags": {
    "Environment": "staging",
    "Project": "permission-aware-rag",
    "ManagedBy": "CDK",
    "CostCenter": "Engineering",
    "Owner": "DevOps Team"
  }
}
