{
  "users": [
    {
      "username": "admin",
      "role": "administrator",
      "description": "システム管理者 / System Administrator"
    },
    {
      "username": "user",
      "role": "user",
      "description": "一般ユーザー / General User"
    }
  ],
  "roles": {
    "administrator": {
      "permissions": [
        "read_documents",
        "search_documents",
        "chat_access",
        "admin_access"
      ],
      "description": "全権限を持つ管理者"
    },
    "user": {
      "permissions": [
        "read_documents",
        "search_documents",
        "chat_access"
      ],
      "description": "基本的な利用権限"
    }
  },
  "settings": {
    "passwordPolicy": {
      "minLength": 8,
      "requireUppercase": true,
      "requireLowercase": true,
      "requireNumbers": true,
      "requireSpecialChars": false
    }
  }
}
