# ===== Permission-aware RAG FSxN CDK =====

# Node.js
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript compiled output
*.js
*.d.ts
*.js.map
!jest.config.js
!docker/nextjs/**/*.js
!docker/nextjs/**/*.mjs

# Next.js
docker/nextjs/.next/
docker/nextjs/out/

# CDK
cdk.out/
cdk.out.*/
cdk.context.json

# 環境変数（.env.exampleは公開対象）
.env
.env.*
!.env.example

# Kiro IDE設定（開発環境固有）
.kiro/

# VS Code設定
.vscode/

# 開発環境固有
development/
backups/

# 機密情報
*.pem
*.key
*.p12
*.pfx

# バックアップファイル
*.backup
*.backup-*
*.bak*
*.disabled
*.broken
*.deprecated

# 一時ファイル
temp/
*.tmp
*.cache
*.log
*.zip

# Lambda結果ファイル
lambda-*-result.json
cloudfront-*-invalidation.json

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Screenshots (local verification only)
screenshots/

# CDK context環境固有ファイル
cdk.context.json.production
cdk.context.json.staging
cdk.context.json.minimal

# 環境固有設定
config/environments/

# Docker一時ファイル
docker/nextjs/lambda-deployment.zip
docker/nextjs/tsconfig.tsbuildinfo

# Embedding server .env (defaults only, no secrets)
!docker/embed/.env
