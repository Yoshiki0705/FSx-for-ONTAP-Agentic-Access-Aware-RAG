{
  "projectName": "perm-rag-demo",
  "environment": "demo",
  "imageTag": "latest",
  "allowedCountries": ["JP"],
  "allowedIps": [],
  "adPassword": "YourStrongP@ssw0rd123",
  "adDomainName": "demo.local",

  // ⚠️ 重要: adPassword を設定すると AWS Managed Microsoft AD が作成されます。
  // このADがIAM Identity CenterのIDソースとして使用されている場合、
  // cdk destroy でADを削除すると Identity Center のユーザーが失われ、
  // マネジメントコンソールにアクセスできなくなる可能性があります。
  // デプロイ前に Identity Center のIDソース設定を確認してください。
  // 推奨: 本番環境やチーム共有環境では、専用のAWSアカウントまたはサンドボックス環境で
  // デプロイすることを強く推奨します。

  // ベクトルストア構成の選択
  // "s3vectors" (デフォルト): S3 Vectors — 低コスト、サブ秒レイテンシ、デモ・開発環境向け
  // "opensearch-serverless": OpenSearch Serverless — 高パフォーマンス、~$700/月、本番環境向け
  "vectorStoreType": "s3vectors",

  // 埋め込みモデル構成（オプション）
  // "titan-text-v2" (デフォルト): Amazon Titan Text Embeddings v2（テキスト専用、1024次元）
  // "nova-multimodal": Amazon Nova Multimodal Embeddings（テキスト・画像・動画・音声、1024次元）
  // ⚠️ 変更には KB 再作成と全データの再インジェストが必要
  // ⚠️ nova-multimodal は us-east-1, us-west-2 のみ対応
  // "embeddingModel": "titan-text-v2",

  // マルチモーダル KB モード（embeddingModel: "nova-multimodal" 時のみ有効）
  // "replace" (デフォルト): 単一 KB（選択した埋め込みモデルのみ）
  // "dual": テキスト専用 KB (titan-text-v2) + マルチモーダル KB (nova-multimodal) の並行運用
  //         段階的なマルチモーダル移行に推奨
  // "multimodalKbMode": "replace",

  // 既存FSx for ONTAP参照（オプション）
  // 指定するとFSx/SVM/Volumeを新規作成せず、既存リソースを参照する
  // デプロイ時間が大幅に短縮される（FSx作成の30-40分待ちが不要）
  // 3つ全て指定するか、全て省略する（一部のみの指定は不可）
  // "existingFileSystemId": "fs-0123456789abcdef0",
  // "existingSvmId": "svm-0123456789abcdef0",
  // "existingVolumeId": "fsvol-0123456789abcdef0",

  // エンタープライズAgent機能（オプション）
  // "enableAgent": Bedrock Agent + Permission-aware Action Group
  // "enableAgentSharing": Agent構成共有S3バケット（JSON export/import、組織内共有）
  // "enableAgentSchedules": Agent定期実行基盤（EventBridge Scheduler + Lambda + DynamoDB実行履歴）
  "enableAgent": true,
  "enableAgentSharing": false,
  "enableAgentSchedules": false,
  // "enableAgentCoreMemory": AgentCore Memory（短期・長期メモリ）。enableAgent=true が前提条件
  "enableAgentCoreMemory": false,
  // "enableEpisodicMemory": エピソード記憶（Episodic Memory）。enableAgentCoreMemory=true が前提条件
  // エージェントの過去の経験（目標、推論ステップ、結果、振り返り）を記録・検索する
  // "enableEpisodicMemory": false,
  // "enableVoiceChat": 音声チャット（Amazon Nova Sonic）。デフォルト: false
  // 有効化すると Lambda に bedrock:InvokeModelWithBidirectionalStream 権限が付与される
  // 推定月額コスト: $70〜$100（入力 ~$0.0019/分、出力 ~$0.0076/分）
  "enableVoiceChat": false,
  // "enableAgentPolicy": AgentCore Policy（エージェント行動制御）。enableAgent=true が前提条件
  // 自然言語でエージェントの行動境界を定義し、リアルタイムにポリシーを強制する
  // "policyFailureMode": ポリシー評価失敗時の挙動（"fail-open" | "fail-closed"、デフォルト: "fail-open"）
  "enableAgentPolicy": false,
  // "policyFailureMode": "fail-open",
  // "enableAgentRegistry": Agent Registry統合（Agent Directory に Registry タブを追加）。enableAgent=true が前提条件
  // 対応リージョン: us-east-1, us-west-2, ap-southeast-2, ap-northeast-1, eu-west-1
  "enableAgentRegistry": false,
  // "agentRegistryRegion": Agent Registry API 呼び出し先リージョン（デフォルト: デプロイリージョン）
  // デプロイリージョンが Agent Registry 非対応の場合に対応リージョンを指定
  // "agentRegistryRegion": "ap-northeast-1",
  // "agentRegistryArn": Agent Registry ARN（事前に create_registry で作成が必要）
  // Preview API のため、CDK 外でレジストリを作成し ARN を指定する
  // 例: aws bedrock-agentcore-control create-registry --name my-registry --authorizer-type AWS_IAM --region ap-northeast-1
  // "agentRegistryArn": "arn:aws:bedrock-agentcore:ap-northeast-1:123456789012:registry/xxxxxxxxxx",
  // "enableAdvancedPermissions": 時間ベースアクセス制御 + 権限判定監査ログ
  "enableAdvancedPermissions": false,

  // ボリューム・S3 Access Point設定
  // "volumeSecurityStyle": "NTFS" or "UNIX"（デフォルト: NTFS）
  // "s3apUserType": "WINDOWS" or "UNIX"（デフォルト: AD設定あり→WINDOWS、なし→UNIX）
  // "s3apUserName": S3 APユーザー名（デフォルト: WINDOWS→Admin、UNIX→root）

  // AD SAMLフェデレーション（オプション）
  // ADユーザーがCloudFront UIから直接サインインし、Cognitoユーザーが自動作成される
  // "enableAdFederation": true,
  // "cloudFrontUrl": "https://d123456abcdef.cloudfront.net",
  //
  // --- Managed ADパターン（adPassword設定時に自動でmanaged） ---
  // adPassword + adDomainName を設定すると AWS Managed Microsoft AD が作成される
  // 注意: SAML IdPメタデータURLの取得には AWS IAM Identity Center の設定が必要:
  //   1. IAM Identity Centerを有効化し、Managed ADをIDソースとして設定
  //   2. SAMLアプリケーションを作成してメタデータURLを取得
  //   3. Managed ADを作成しただけではSAMLメタデータエンドポイントは提供されない
  // IAM Identity Center以外のIdP（AD FS等）を使用する場合は samlMetadataUrl を指定:
  // "samlMetadataUrl": "https://your-adfs-server/federationmetadata/2007-06/federationmetadata.xml",
  //
  // --- Self-managed ADパターン ---
  // EC2上のAD + Entra Connect連携の場合:
  // "adEc2InstanceId": "i-0123456789abcdef0",
  // "samlMetadataUrl": "https://login.microsoftonline.com/{tenant-id}/federationmetadata/2007-06/federationmetadata.xml"
  "enableAdFederation": false,

  // 監視・アラート機能（オプション）
  // CloudWatchダッシュボード、SNSアラート、EventBridge連携
  // "enableMonitoring": true,
  // "monitoringEmail": "ops@example.com",
  // "enableAgentCoreObservability": false,
  // "alarmEvaluationPeriods": 1,
  // "dashboardRefreshInterval": 300
  "enableMonitoring": false,

  // ========================================================================
  // Guardrails 詳細設定（オプション）
  // enableGuardrails=true 時に Guardrails のコンテンツフィルタ強度、トピックポリシー、
  // PII 検出設定を詳細に制御する。未設定時はデフォルト構成（全カテゴリ HIGH）が適用される。
  // enableGuardrails=false 時は guardrailsConfig は無視される。
  // ========================================================================
  //
  // "enableGuardrails": true,
  // "guardrailsConfig": {
  //   // コンテンツフィルタ: カテゴリ別の入力・出力フィルタ強度（NONE / LOW / MEDIUM / HIGH）
  //   "contentFilters": [
  //     { "type": "SEXUAL", "inputStrength": "HIGH", "outputStrength": "HIGH" },
  //     { "type": "VIOLENCE", "inputStrength": "MEDIUM", "outputStrength": "HIGH" },
  //     { "type": "HATE", "inputStrength": "HIGH", "outputStrength": "HIGH" },
  //     { "type": "INSULTS", "inputStrength": "LOW", "outputStrength": "MEDIUM" },
  //     { "type": "MISCONDUCT", "inputStrength": "HIGH", "outputStrength": "HIGH" },
  //     { "type": "PROMPT_ATTACK", "inputStrength": "HIGH", "outputStrength": "NONE" }
  //   ],
  //   // トピックポリシー: 特定トピックの検出・ブロック
  //   "topicPolicies": [
  //     {
  //       "name": "CompetitorInfo",
  //       "definition": "競合他社の製品情報や価格に関する質問",
  //       "examples": ["競合のA社の製品と比較して"],
  //       "action": "BLOCK"
  //     }
  //   ],
  //   // PII 検出: エンティティタイプ別のアクション（BLOCK / ANONYMIZE）
  //   "piiConfig": [
  //     { "type": "EMAIL", "action": "ANONYMIZE" },
  //     { "type": "PHONE", "action": "ANONYMIZE" },
  //     { "type": "CREDIT_DEBIT_CARD_NUMBER", "action": "BLOCK" }
  //   ],
  //   // コンテキスト接地チェック: ハルシネーション防止（true で有効化）
  //   "contextualGrounding": true,
  //   "groundingThreshold": 0.7,
  //   "relevanceThreshold": 0.7
  // },

  // ========================================================================
  // OIDC IdP連携（オプション）
  // Keycloak、Okta、Entra ID等のOIDC準拠IdPからのサインインを有効化
  // 設定するとCognito User PoolにOIDC IdPが登録され、サインイン画面にOIDCボタンが表示される
  // enableAdFederation=true と併用可能（SAML + OIDC ハイブリッド構成）
  //
  // ⚠️ issuerUrl の注意: IdPのOpenID Configuration（/.well-known/openid-configuration）の
  //    "issuer" フィールドの値と完全一致させてください。Auth0は末尾スラッシュ付き
  //    （例: "https://xxx.us.auth0.com/"）、Keycloakは末尾スラッシュなし
  //    （例: "https://keycloak.example.com/realms/main"）です。
  //    不一致の場合、Cognitoのトークン検証で "invalid_request" エラーが発生します。
  // ========================================================================
  //
  // --- OIDC + LDAP構成例 ---
  // OpenLDAP/FreeIPA環境でKeycloak等のOIDC IdPを使用する場合:
  // ※ cloudFrontUrlはOAuthコールバックに必要です
  //
  // "enableAdFederation": false,
  // "cloudFrontUrl": "https://dxxxxxxxx.cloudfront.net",
  // "oidcProviderConfig": {
  //   "providerName": "Keycloak",
  //   "clientId": "rag-system",
  //   "clientSecret": "arn:aws:secretsmanager:ap-northeast-1:123456789012:secret:oidc-client-secret",
  //   "issuerUrl": "https://keycloak.example.com/realms/main",
  //   "groupClaimName": "groups"
  // },
  // "ldapConfig": {
  //   "ldapUrl": "ldaps://ldap.example.com:636",
  //   "baseDn": "dc=example,dc=com",
  //   "bindDn": "cn=readonly,dc=example,dc=com",
  //   "bindPasswordSecretArn": "arn:aws:secretsmanager:ap-northeast-1:123456789012:secret:ldap-bind-password",
  //   "userSearchFilter": "(mail={email})",
  //   "groupSearchFilter": "(member={dn})"
  // },
  // "permissionMappingStrategy": "uid-gid",
  //
  // --- SAML + OIDC ハイブリッド構成例 ---
  // 既存AD SAML Federation + OIDC IdP（Okta等）を併用する場合:
  //
  // "enableAdFederation": true,
  // "adType": "managed",
  // "adDirectoryId": "d-0123456789",
  // "samlMetadataUrl": "https://portal.sso.ap-northeast-1.amazonaws.com/saml/metadata/...",
  // "oidcProviderConfig": {
  //   "providerName": "Okta",
  //   "clientId": "0oa1234567890",
  //   "clientSecret": "arn:aws:secretsmanager:...",
  //   "issuerUrl": "https://company.okta.com"
  // },
  // "permissionMappingStrategy": "hybrid",
  // "cloudFrontUrl": "https://dxxxxxxxx.cloudfront.net",
  //
  // --- ONTAP name-mapping連携（オプション） ---
  // UNIXユーザー名とWindowsユーザー名の対応付けを有効化
  // "ontapNameMappingEnabled": true
  //
  // --- ONTAP name-mapping + REST API設定例 ---
  // fsxadminパスワードは事前に aws fsx update-file-system で設定が必要
  // SVM UUIDは aws fsx describe-storage-virtual-machines で取得
  // "ontapNameMappingEnabled": true,
  // "ontapMgmtIp": "10.0.2.27",
  // "ontapSvmUuid": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
  // "ontapAdminSecretArn": "arn:aws:secretsmanager:ap-northeast-1:123456789012:secret:ontap-fsxadmin-password"

  // ========================================================================
  // マルチエージェント協調（Multi-Agent Collaboration）
  // Supervisor + Collaborator パターンによる高度なマルチエージェント処理
  // enableAgent=true が前提条件。デフォルト無効のため追加コストは発生しない
  //
  // ⚠️ デプロイ注意事項:
  // - CloudFormation AgentCollaboration の有効値: DISABLED | SUPERVISOR | SUPERVISOR_ROUTER のみ
  //   （COLLABORATOR は無効値。Collaborator Agent は AgentCollaboration を設定しない）
  // - Supervisor Agent は2段階デプロイが必要:
  //   1. AgentCollaboration=DISABLED で作成
  //   2. Custom Resource Lambda で SUPERVISOR_ROUTER に変更 + AssociateAgentCollaborator + PrepareAgent
  // - Supervisor IAM ロール: bedrock:GetAgentAlias + bedrock:InvokeAgent (agent-alias/*/*)
  // - Custom Resource Lambda: iam:PassRole (Supervisor ロール用) が必要
  // - autoPrepare=true は Supervisor Agent では使用不可（Collaborator なしで失敗）
  // - 各 Collaborator Agent は CfnAgentAlias が必要（Supervisor からの参照に必須）
  // ========================================================================
  // "enableMultiAgent": マルチエージェント協調。enableAgent=true 時はデフォルト有効。
  // Bedrock Agent は待機コストゼロのため、有効化しても追加ランニングコストは発生しない。
  // マルチAgentモードで実際にチャットした場合のみトークン消費が 3-6 倍になる。
  // 明示的に false を設定した場合のみ無効化される。
  // "enableMultiAgent": false,
  // "supervisorRoutingMode": "supervisor_router",
  // "supervisorAutoRouting": false,
  // "enableVisionAgent": false,
  // "defaultAgentMode": "single",
  // "retrievalMaxResults": 5,
  // "mcpConnectors": [],
  // "collaboratorModels": {},
  // "ontapNameMappingEnabled": false,
  //
  // Agent instruction の回答言語設定:
  //   "auto" (デフォルト) = ユーザーの入力言語に合わせて回答
  //   "Japanese" / "English" / "Korean" 等 = 指定言語で固定回答
  // "agentLanguage": "auto"

  // ========================================================================
  // Phase 2 拡張機能（オプション）
  // ========================================================================

  // --- マルチOIDC IdP構成例 ---
  // 複数のOIDC IdP（Okta + Keycloak等）を同時登録する場合:
  // ※ oidcProviderConfig（単一IdP）と oidcProviders（複数IdP）は排他的設定
  //    両方を同時に指定するとバリデーションエラーが発生する
  //
  // "oidcProviders": [
  //   {
  //     "providerName": "Okta",
  //     "clientId": "0oa1234567890",
  //     "clientSecret": "arn:aws:secretsmanager:ap-northeast-1:123456789012:secret:okta-client-secret",
  //     "issuerUrl": "https://company.okta.com",
  //     "groupClaimName": "groups"
  //   },
  //   {
  //     "providerName": "Keycloak",
  //     "clientId": "rag-system",
  //     "clientSecret": "arn:aws:secretsmanager:ap-northeast-1:123456789012:secret:keycloak-client-secret",
  //     "issuerUrl": "https://keycloak.example.com/realms/main",
  //     "groupClaimName": "roles"
  //   }
  // ],

  // --- LDAP TLS証明書検証設定例 ---
  // 社内PKI環境でカスタムCA証明書を使用する場合:
  // tlsCaCertArn: Secrets ManagerにPEM形式で保存したCA証明書のARN
  // tlsRejectUnauthorized: false にすると自己署名証明書を許可（開発・テスト環境用）
  //
  // "ldapConfig": {
  //   "ldapUrl": "ldaps://ldap.example.com:636",
  //   "baseDn": "dc=example,dc=com",
  //   "bindDn": "cn=readonly,dc=example,dc=com",
  //   "bindPasswordSecretArn": "arn:aws:secretsmanager:ap-northeast-1:123456789012:secret:ldap-bind-password",
  //   "userSearchFilter": "(mail={email})",
  //   "groupSearchFilter": "(member={dn})",
  //   "tlsCaCertArn": "arn:aws:secretsmanager:ap-northeast-1:123456789012:secret:ldap-ca-cert",
  //   "tlsRejectUnauthorized": true
  // },

  // --- Fail-Closedモード設定例 ---
  // 高セキュリティ環境向け: 権限取得失敗時にサインイン自体をブロックする
  // "fail-open"（デフォルト）: 権限取得失敗時もサインインを継続（エラーログのみ記録）
  // "fail-closed": 権限取得失敗時にサインインをブロック（管理者への連絡メッセージを表示）
  //
  // "authFailureMode": "fail-closed",

  // --- LDAPヘルスチェック設定例 ---
  // ldapConfig指定時にLDAP接続の正常性を自動検証する
  // EventBridge Ruleで5分間隔の定期実行、CloudWatch Alarmで障害検知
  // デフォルト: true（ldapConfig指定時は自動有効化）
  // 検証済み: OpenLDAP EC2に対してLambda手動実行で全ステップSUCCESS（total: 501ms）
  // VPC内LambdaはNATゲートウェイ経由でSecrets Manager + CloudWatch Metricsにアクセス
  // enableVpcEndpoints=true でVPCエンドポイント経由のアクセスも可能
  //
  // "healthCheckEnabled": true,

  // --- 監査ログ設定例 ---
  // 認証イベントの監査証跡をDynamoDBテーブルに永続化する
  // サインイン成功/失敗イベントを記録し、TTLで自動削除
  // auditLogRetentionDays: 監査ログの保持日数（デフォルト: 90日）
  //
  // "auditLogEnabled": true,
  // "auditLogRetentionDays": 90
}
