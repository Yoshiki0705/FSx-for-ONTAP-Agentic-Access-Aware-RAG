{
  "projectName": "perm-rag-demo",
  "environment": "demo",
  "imageTag": "latest",
  "allowedCountries": ["JP"],
  "allowedIps": [],
  "adPassword": "YourStrongP@ssw0rd123",
  "adDomainName": "demo.local",

  // ベクトルストア構成の選択
  // "s3vectors" (デフォルト): S3 Vectors — 低コスト、サブ秒レイテンシ、デモ・開発環境向け
  // "opensearch-serverless": OpenSearch Serverless — 高パフォーマンス、~$700/月、本番環境向け
  "vectorStoreType": "s3vectors",

  // 既存FSx for ONTAP参照（オプション）
  // 指定するとFSx/SVM/Volumeを新規作成せず、既存リソースを参照する
  // デプロイ時間が大幅に短縮される（FSx作成の30-40分待ちが不要）
  // 3つ全て指定するか、全て省略する（一部のみの指定は不可）
  // "existingFileSystemId": "fs-0123456789abcdef0",
  // "existingSvmId": "svm-0123456789abcdef0",
  // "existingVolumeId": "fsvol-0123456789abcdef0",

  // エンタープライズAgent機能（オプション）
  // "enableAgent": Bedrock Agent + Permission-aware Action Group
  // "enableAgentSharing": Agent構成共有S3バケット（JSON export/import、組織内共有）
  // "enableAgentSchedules": Agent定期実行基盤（EventBridge Scheduler + Lambda + DynamoDB実行履歴）
  "enableAgent": true,
  "enableAgentSharing": false,
  "enableAgentSchedules": false,
  // "enableAgentCoreMemory": AgentCore Memory（短期・長期メモリ）。enableAgent=true が前提条件
  "enableAgentCoreMemory": false,
  // "enableAdvancedPermissions": 時間ベースアクセス制御 + 権限判定監査ログ
  "enableAdvancedPermissions": false,

  // ボリューム・S3 Access Point設定
  // "volumeSecurityStyle": "NTFS" or "UNIX"（デフォルト: NTFS）
  // "s3apUserType": "WINDOWS" or "UNIX"（デフォルト: AD設定あり→WINDOWS、なし→UNIX）
  // "s3apUserName": S3 APユーザー名（デフォルト: WINDOWS→Admin、UNIX→root）

  // AD SAMLフェデレーション（オプション）
  // ADユーザーがCloudFront UIから直接サインインし、Cognitoユーザーが自動作成される
  // "enableAdFederation": true,
  // "cloudFrontUrl": "https://d123456abcdef.cloudfront.net",
  //
  // --- Managed ADパターン（adPassword設定時に自動でmanaged） ---
  // adPassword + adDomainName を設定すると AWS Managed Microsoft AD が作成される
  // 注意: SAML IdPメタデータURLの取得には AWS IAM Identity Center の設定が必要:
  //   1. IAM Identity Centerを有効化し、Managed ADをIDソースとして設定
  //   2. SAMLアプリケーションを作成してメタデータURLを取得
  //   3. Managed ADを作成しただけではSAMLメタデータエンドポイントは提供されない
  // IAM Identity Center以外のIdP（AD FS等）を使用する場合は samlMetadataUrl を指定:
  // "samlMetadataUrl": "https://your-adfs-server/federationmetadata/2007-06/federationmetadata.xml",
  //
  // --- Self-managed ADパターン ---
  // EC2上のAD + Entra Connect連携の場合:
  // "adEc2InstanceId": "i-0123456789abcdef0",
  // "samlMetadataUrl": "https://login.microsoftonline.com/{tenant-id}/federationmetadata/2007-06/federationmetadata.xml"
  "enableAdFederation": false,

  // 監視・アラート機能（オプション）
  // CloudWatchダッシュボード、SNSアラート、EventBridge連携
  // "enableMonitoring": true,
  // "monitoringEmail": "ops@example.com",
  // "enableAgentCoreObservability": false,
  // "alarmEvaluationPeriods": 1,
  // "dashboardRefreshInterval": 300
  "enableMonitoring": false
}
